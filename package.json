{
  "name": "adjudication",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Criminal charge adjudication: offense mapping -> decision matrix (v5 taxonomy).",
  "scripts": {
    "predev": "npm run build:data",
    "dev": "vite",
    "prebuild": "npm run build:data",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "build:data": "tsx scripts/build-data.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build:embeddings": "tsx scripts/build-embeddings.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8",
    "xlsx": "^0.18.5"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0"
  }
}
