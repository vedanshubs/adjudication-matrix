{
  "name": "adjudication",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Criminal charge adjudication: offense mapping -> decision matrix (v5 taxonomy).",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "build:data": "tsx scripts/build-data.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build:embeddings": "tsx scripts/build-embeddings.ts",
    "eval:statute": "tsx scripts/eval-statute.ts",
    "build:goldset": "tsx scripts/build-goldset.ts",
    "eval:score": "tsx scripts/eval-score.ts",
    "eval:llm": "tsx scripts/eval-llm.ts",
    "make:deck": "tsx scripts/make-deck.ts",
    "make:deck:rag": "tsx scripts/make-deck-rag.ts",
    "punchlist": "tsx scripts/taxonomy-punchlist.ts",
    "eval:recall": "tsx scripts/eval-recall.ts",
    "eval:rag": "tsx scripts/eval-rag.ts",
    "api": "tsx scripts/api-server.ts"
  },
  "devDependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1087.0",
    "@types/node": "^22.10.0",
    "pptxgenjs": "^4.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8",
    "xlsx": "^0.18.5"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0"
  }
}
